{
  "info": {
    "name": "Restful-Booker — QA Portfolio",
    "description": "Colección completa de pruebas funcionales de la API Restful-Booker. Incluye 8 requests con métodos correctos, headers, bodies y test scripts de validación automática. Ejecutar en orden de 1 a 8.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://restful-booker.herokuapp.com",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "booking_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - GET Health Check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-API-001 | Status 201 - API activa', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('TC-API-001 | Response body es Created', function () {",
              "    pm.expect(pm.response.text()).to.equal('Created');",
              "});",
              "",
              "pm.test('TC-API-001 | Tiempo de respuesta menor a 3000ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/ping",
          "host": ["{{base_url}}"],
          "path": ["ping"]
        },
        "description": "Verifica que la API está disponible. Status esperado: 201 Created."
      },
      "response": []
    },
    {
      "name": "02 - POST Autenticacion (genera token)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-API-002 | Status 200 - Autenticacion exitosa', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('TC-API-002 | Response contiene token', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('token');",
              "    pm.expect(jsonData.token).to.not.be.empty;",
              "});",
              "",
              "// Guarda el token automaticamente en la variable de coleccion",
              "const jsonData = pm.response.json();",
              "if (jsonData.token) {",
              "    pm.collectionVariables.set('token', jsonData.token);",
              "    console.log('Token guardado: ' + jsonData.token);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/auth",
          "host": ["{{base_url}}"],
          "path": ["auth"]
        },
        "description": "Genera un token de autenticacion. El token se guarda automaticamente en {{token}} para las requests siguientes."
      },
      "response": []
    },
    {
      "name": "03 - GET Listar todas las reservas",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-API-003 | Status 200 - Listado exitoso', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('TC-API-003 | Response es un array', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test('TC-API-003 | Array contiene al menos una reserva', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.length).to.be.above(0);",
              "});",
              "",
              "pm.test('TC-API-003 | Cada elemento contiene bookingid', function () {",
              "    const jsonData = pm.response.json();",
              "    jsonData.forEach(function(item) {",
              "        pm.expect(item).to.have.property('bookingid');",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/booking",
          "host": ["{{base_url}}"],
          "path": ["booking"]
        },
        "description": "Retorna un array con los IDs de todas las reservas existentes."
      },
      "response": []
    },
    {
      "name": "04 - GET Obtener reserva por ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-API-004 | Status 200 - Reserva encontrada', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('TC-API-004 | Response contiene campos obligatorios', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('firstname');",
              "    pm.expect(jsonData).to.have.property('lastname');",
              "    pm.expect(jsonData).to.have.property('totalprice');",
              "    pm.expect(jsonData).to.have.property('depositpaid');",
              "    pm.expect(jsonData).to.have.property('bookingdates');",
              "});",
              "",
              "pm.test('TC-API-004 | bookingdates contiene checkin y checkout', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.bookingdates).to.have.property('checkin');",
              "    pm.expect(jsonData.bookingdates).to.have.property('checkout');",
              "});",
              "",
              "pm.test('TC-API-004 | totalprice es un numero positivo', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.totalprice).to.be.a('number');",
              "    pm.expect(jsonData.totalprice).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/booking/1",
          "host": ["{{base_url}}"],
          "path": ["booking", "1"]
        },
        "description": "Retorna el detalle completo de la reserva con ID 1."
      },
      "response": []
    },
    {
      "name": "05 - POST Crear nueva reserva",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-API-005 | Status 200 - Reserva creada', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('TC-API-005 | Response contiene bookingid', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('bookingid');",
              "    pm.expect(jsonData.bookingid).to.be.a('number');",
              "});",
              "",
              "pm.test('TC-API-005 | Datos del booking coinciden con lo enviado', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.booking.firstname).to.equal('Samuel');",
              "    pm.expect(jsonData.booking.lastname).to.equal('Ospina');",
              "    pm.expect(jsonData.booking.totalprice).to.equal(250);",
              "    pm.expect(jsonData.booking.depositpaid).to.equal(true);",
              "});",
              "",
              "// Guarda el booking_id automaticamente para las requests siguientes",
              "const jsonData = pm.response.json();",
              "if (jsonData.bookingid) {",
              "    pm.collectionVariables.set('booking_id', jsonData.bookingid);",
              "    console.log('Booking ID guardado: ' + jsonData.bookingid);",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Samuel\",\n  \"lastname\": \"Ospina\",\n  \"totalprice\": 250,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-08-01\",\n    \"checkout\": \"2026-08-05\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/booking",
          "host": ["{{base_url}}"],
          "path": ["booking"]
        },
        "description": "Crea una nueva reserva. El bookingid generado se guarda automaticamente en {{booking_id}}."
      },
      "response": []
    },
    {
      "name": "06 - PUT Actualizar reserva completa",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-API-006 | Status 200 - Actualizacion exitosa', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('TC-API-006 | Firstname actualizado correctamente', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.firstname).to.equal('Samuel');",
              "});",
              "",
              "pm.test('TC-API-006 | Lastname actualizado correctamente', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.lastname).to.equal('Ospina Updated');",
              "});",
              "",
              "pm.test('TC-API-006 | Precio actualizado a 300', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.totalprice).to.equal(300);",
              "});",
              "",
              "pm.test('TC-API-006 | Response contiene todos los campos', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.all.keys(",
              "        'firstname', 'lastname', 'totalprice', 'depositpaid', 'bookingdates', 'additionalneeds'",
              "    );",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Samuel\",\n  \"lastname\": \"Ospina Updated\",\n  \"totalprice\": 300,\n  \"depositpaid\": false,\n  \"bookingdates\": {\n    \"checkin\": \"2026-09-01\",\n    \"checkout\": \"2026-09-05\"\n  },\n  \"additionalneeds\": \"Lunch\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/booking/{{booking_id}}",
          "host": ["{{base_url}}"],
          "path": ["booking", "{{booking_id}}"]
        },
        "description": "Actualiza todos los campos de la reserva creada en el paso 05. Requiere token en Cookie."
      },
      "response": []
    },
    {
      "name": "07 - PATCH Actualizar reserva parcialmente",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-API-007 | Status 200 - Actualizacion parcial exitosa', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('TC-API-007 | Firstname actualizado a Carlos', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.firstname).to.equal('Carlos');",
              "});",
              "",
              "pm.test('TC-API-007 | Lastname actualizado a Rodriguez', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.lastname).to.equal('Rodriguez');",
              "});",
              "",
              "pm.test('TC-API-007 | Precio no fue modificado (sigue en 300)', function () {",
              "    const jsonData = pm.response.json();",
              "    pm.expect(jsonData.totalprice).to.equal(300);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Cookie",
            "value": "token={{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstname\": \"Carlos\",\n  \"lastname\": \"Rodriguez\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/booking/{{booking_id}}",
          "host": ["{{base_url}}"],
          "path": ["booking", "{{booking_id}}"]
        },
        "description": "Actualiza solo firstname y lastname. Los demas campos deben permanecer sin cambios."
      },
      "response": []
    },
    {
      "name": "08 - DELETE Eliminar reserva",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// BUG-001: DELETE devuelve 201 en vez de 204",
              "// La operacion funciona correctamente pero el status code no sigue el estandar HTTP",
              "pm.test('TC-API-008 | Status recibido: 201 (BUG: deberia ser 204)', function () {",
              "    pm.response.to.have.status(201);",
              "    console.log('BUG-001 confirmado: DELETE retorna 201 en vez de 204 No Content');",
              "});",
              "",
              "pm.test('TC-API-008 | Body contiene Deleted (confirmacion de eliminacion)', function () {",
              "    pm.expect(pm.response.text()).to.include('Created');",
              "});",
              "",
              "// Limpia la variable booking_id ya que la reserva fue eliminada",
              "pm.collectionVariables.set('booking_id', '');"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Cookie",
            "value": "token={{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/booking/{{booking_id}}",
          "host": ["{{base_url}}"],
          "path": ["booking", "{{booking_id}}"]
        },
        "description": "Elimina la reserva creada en el paso 05. HALLAZGO: devuelve 201 Created en vez de 204 No Content (estandar HTTP para DELETE exitoso sin cuerpo de respuesta)."
      },
      "response": []
    },
    {
      "name": "09 - GET Verificar eliminacion (debe retornar 404)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Esta request usa el booking_id del paso 05 que ya fue eliminado",
              "// Si el ID esta vacio, la prueba no es valida",
              "console.log('Verificando que booking_id fue eliminado. ID usado: ' + pm.collectionVariables.get('booking_id'));"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('TC-API-009 | Status 404 - Reserva eliminada correctamente', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "pm.test('TC-API-009 | La reserva ya no existe en el sistema', function () {",
              "    pm.expect(pm.response.text()).to.include('Not Found');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/booking/{{booking_id}}",
          "host": ["{{base_url}}"],
          "path": ["booking", "{{booking_id}}"]
        },
        "description": "Verifica que la reserva eliminada en el paso 08 ya no existe. Debe retornar 404. Esta es la validacion final del flujo CRUD completo."
      },
      "response": []
    }
  ]
}
